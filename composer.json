{
    "name": "psychedcms/psychedcms-core",
    "description": "Core components for PsychedCMS - Content management building blocks for PHP domain entities",
    "type": "psychedcms",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "api-platform/core": "^4.0",
        "doctrine/doctrine-bundle": "^2.18",
        "doctrine/orm": "^3.6",
        "gedmo/doctrine-extensions": "^3.0",
        "symfony/html-sanitizer": "^7.4",
        "symfony/serializer": "^7.4",
        "symfony/string": "^7.4",
        "symfony/validator": "^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "PsychedCms\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PsychedCms\\Core\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
